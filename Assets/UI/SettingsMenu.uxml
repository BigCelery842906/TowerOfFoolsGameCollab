            <ui:Button name="btn-return" style="width: 400px; align-self: center; align-content: center; justify-content: center; align-items: auto; bottom: 0; display: flex; padding-left: 0; padding-right: 0; margin-right: 16px; margin-left: 16px; background-image: url(&quot;project://database/Assets/UI/Assets/Button_Plate_Flat_Default.png?fileID=2800000&amp;guid=fafcb099286da4f489fd0675a391dba3&amp;type=3#Button_Plate_Flat_Default&quot;); height: 20%;">
